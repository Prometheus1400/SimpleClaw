FROM rust:1-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        bubblewrap \
        ca-certificates \
        clang \
        cmake \
        git \
        libssl-dev \
        pkg-config \
        socat \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

ENV CARGO_TERM_COLOR=always
ENV PATH=/usr/local/cargo/bin:/usr/local/rustup/bin:${PATH}

CMD ["bash"]
